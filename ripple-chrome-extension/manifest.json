{
  "manifest_version": 3,
  "name": "Ripple Bridge (WhatsApp + Gmail + Slack + Outlook + Teams)",
  "version": "1.9.0",
  "description": "Ripple automation + P8 cross-app memory ingest (Gmail, Slack, Outlook, Teams).",
  "permissions": ["nativeMessaging", "tabs", "scripting", "downloads"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://www.youtube.com/*",
    "https://www.linkedin.com/*",
    "https://www.instagram.com/*",
    "https://mail.google.com/*",
    "https://app.slack.com/*",
    "https://*.slack.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://teams.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js", "whatsappIngest.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["youtubeContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["linkedinContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["instagramContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["gmailContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.slack.com/*", "https://*.slack.com/*"],
      "js": ["slackContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": ["outlookContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://teams.microsoft.com/*"],
      "js": ["teamsContent.js"],
      "run_at": "document_idle"
    }
  ]
}
