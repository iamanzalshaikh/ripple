VITE_API_URL=http://127.0.0.1:3007/api/v1

# Live E2E tests: npm run test:e2e:live (backend must be running)
RIPPLE_TEST_TOKEN=
# RIPPLE_TEST_EMAIL=
# RIPPLE_TEST_PASSWORD=

# Production: ripple-chrome-extension + native-host/install-windows.ps1 (WHATSAPP_SETUP.md)

# Dev only:
# RIPPLE_USE_CDP=1
# RIPPLE_USE_WS_BRIDGE=1

# P8.5 planner flags — set in ripple-desktop/.env (Electron main), NOT ripple-backend/.env
# RIPPLE_P85_PHASE_B=1          # Stage 1: compound split + log; clarify unresolved tail
# RIPPLE_P85_PHASE_B=2          # Stage 2: execute resolved steps then clarify (future)
# RIPPLE_P85_TRACE=1            # Planner branch trace
# RIPPLE_P85_COMPOUND_STICKY=0  # Rollback compound gate to legacy fallthrough
# RIPPLE_P85_KILL=1             # Disable P8.5; legacy routers only
