{
  "name": "ripple-desktop",
  "version": "0.1.0",
  "description": "Ripple desktop AI assistant",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:stop": "node scripts/stop-dev.mjs",
    "dev:fresh": "node scripts/stop-dev.mjs && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:phase4": "vitest run electron/automation/voice/nlu/__tests__",
    "test:p4": "vitest run electron/automation/voice/nlu/__tests__/phase4.7-i18n.spec.ts electron/automation/voice/nlu/__tests__/phase4-slang-matrix.spec.ts electron/automation/voice/nlu/__tests__/spokenResponses.spec.ts electron/automation/voice/nlu/__tests__/e2e-production.spec.ts",
    "test:integration": "vitest run electron/automation/desktop/__tests__",
    "test:e2e": "vitest run electron/automation/voice/nlu/__tests__/e2e-production.spec.ts electron/automation/desktop/__tests__/disk.integration.spec.ts electron/automation/voice/nlu/__tests__/phase4-voice-whisper.spec.ts",
    "test:e2e:full": "vitest run electron/automation/voice/nlu/__tests__/e2e-production.spec.ts electron/automation/voice/nlu/__tests__/e2e-live-whisper.spec.ts electron/automation/voice/nlu/__tests__/phase4-live-smoke.spec.ts electron/automation/desktop/__tests__/disk.integration.spec.ts electron/automation/voice/nlu/__tests__/phase4-voice-whisper.spec.ts",
    "test:e2e:local": "vitest run electron/automation/voice/nlu/__tests__/e2e-production.spec.ts electron/automation/voice/nlu/__tests__/phase4-voice-whisper.spec.ts electron/automation/desktop/__tests__/disk.integration.spec.ts",
    "test:e2e:live": "node scripts/run-vitest-live.mjs run electron/automation/voice/nlu/__tests__/e2e-live-whisper.spec.ts electron/automation/voice/nlu/__tests__/phase4-live-smoke.spec.ts",
    "test:ci:gate": "vitest run electron/telemetry/__tests__/ci-gate.spec.ts",
    "test:p6": "vitest run electron/telemetry/__tests__/ci-gate.spec.ts electron/telemetry/__tests__/observabilityDashboard.spec.ts",
    "test:ci": "vitest run electron/telemetry/__tests__/ci-gate.spec.ts electron/telemetry/__tests__/observabilityDashboard.spec.ts electron/native/__tests__/phase-p7-native.spec.ts electron/automation/retriever/__tests__/phase-p8-semantic.spec.ts electron/automation/safety electron/automation/retriever electron/storage/__tests__/workflowGraph.spec.ts electron/storage/__tests__/knowledgeGraph.spec.ts electron/storage/__tests__/indexConfig.spec.ts electron/automation/desktop/__tests__/phase-p55-workflow.spec.ts electron/automation/desktop/__tests__/phase-p47-undo.spec.ts electron/automation/voice/nlu/__tests__/phase4-ai-first-routing.spec.ts",
    "seed:p8b": "vitest run electron/storage/__tests__/p8b-seed-cli.spec.ts --maxWorkers=1",
    "native:build": "node scripts/run-cargo.mjs build --release --manifest-path ripple-native/Cargo.toml --target-dir ripple-native/target && node scripts/copy-native-build.mjs",
    "native:build:debug": "node scripts/run-cargo.mjs build --manifest-path ripple-native/Cargo.toml --target-dir ripple-native/target",
    "native:dev": "node scripts/run-cargo.mjs run --manifest-path ripple-native/Cargo.toml --target-dir ripple-native/target",
    "native:test-send": "node scripts/test-p7d-sendinput.mjs",
    "native:test-a11y": "node scripts/test-p7e-a11y.mjs",
    "native:test-ocr": "node scripts/test-p7f-ocr.mjs",
    "native:test-mouse": "node scripts/test-p7g-mouse.mjs",
    "native:register-task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-native-task.ps1",
    "native:sign": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sign-native.ps1",
    "test:p9": "vitest run electron/agent/__tests__/phase-p9-agent.spec.ts",
    "test:p85": "vitest run electron/agent/__tests__/phase-p85-planner.spec.ts electron/agent/__tests__/phase-p85-planner-v2.spec.ts electron/agent/__tests__/phase-p85-e4-e7-matrix.spec.ts electron/agent/__tests__/phase-p85-full-suite.spec.ts electron/agent/__tests__/phase-p85-paint-draw.spec.ts electron/agent/__tests__/phase-p85-v2-forgiving.spec.ts electron/agent/__tests__/phase-p85-execution-sync.spec.ts electron/agent/__tests__/phase-p85-legacy-bridge.spec.ts electron/agent/__tests__/phase-p85-memory-search.spec.ts electron/agent/__tests__/phase-p85-messaging-adapter-gate.spec.ts electron/agent/__tests__/phase-p85-app-workspace-split.spec.ts electron/agent/__tests__/phase-p85-runtime-trace.spec.ts electron/agent/__tests__/phase-p85-phase-b-split.spec.ts electron/agent/__tests__/phase-p85-plan-validator.spec.ts electron/agent/__tests__/phase-p85-utterance-fixtures.spec.ts electron/agent/__tests__/phase-p85-tool-manifest.spec.ts electron/agent/__tests__/phase-p85-wave2.spec.ts electron/agent/__tests__/phase-p85-dashboard.spec.ts electron/agent/__tests__/phase-p85-phase0-scaffold.spec.ts electron/agent/__tests__/phase-p85-phase1-desktop-tools.spec.ts electron/agent/__tests__/phase-p85-core-desktop-e2e.spec.ts electron/agent/__tests__/phase-p85-phase2-safety.spec.ts electron/agent/__tests__/phase-p85-phase2-pipeline.spec.ts electron/agent/__tests__/phase-p85-phase3-shadow.spec.ts electron/agent/__tests__/phase-p85-phase4-router.spec.ts electron/agent/__tests__/phase-p85-phase5-filesystem.spec.ts electron/agent/__tests__/phase-p85-phase5-system.spec.ts electron/agent/__tests__/phase-p85-desktop-payload-filesystem.spec.ts electron/agent/__tests__/phase-p85-whatsapp-tool.spec.ts electron/agent/__tests__/phase-p85-whatsapp-final.spec.ts electron/agent/__tests__/phase-p85-youtube-tool.spec.ts electron/agent/__tests__/phase-p85-gmail-tool.spec.ts electron/agent/__tests__/phase-p85-context-routing.spec.ts electron/agent/__tests__/phase-p85-linkedin-tool.spec.ts electron/agent/__tests__/phase-p9-agent.spec.ts",
    "test:ui-matrix": "node scripts/ui-test-e4-e7-matrix.mjs",
    "test:ui-os": "node scripts/ui-test-p85-os.mjs",
    "test:ui-os-only": "node scripts/ui-test-p85-os.mjs --os-only",
    "test:ui-os-phase1": "node scripts/ui-test-p85-os.mjs --os-only --phase1-only",
    "test:ui-os-e7": "node scripts/ui-test-p85-os.mjs --os-only --e7-only",
    "test:ui-os-e7-clipboard": "node scripts/ui-test-p85-os.mjs --os-only --e7-clipboard-only",
    "generate:tool-manifest": "vitest run electron/agent/__tests__/phase-p85-tool-manifest.spec.ts",
    "test:fetch-token": "node scripts/fetch-test-token.mjs",
    "test:live": "node scripts/run-vitest-live.mjs run electron/automation/voice/nlu/__tests__/phase4-live-smoke.spec.ts",
    "pack": "npm run native:build && npm run build && electron-builder",
    "pack:win": "npm run native:build && npm run build && electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "keytar": "^7.9.0",
    "puppeteer-core": "^24.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io-client": "^4.8.3",
    "ws": "^8.21.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.10.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
